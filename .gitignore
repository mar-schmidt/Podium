# Go
/podium
/podiumd
/bin/
*.exe
*.test
*.out
*.prof
/dist/

# Web build artifacts (embedded at build time). The placeholder
# web/dist/index.html is tracked so `go build` works pre-frontend-build; the
# vite-generated hashed assets are not committed.
/web/node_modules/
/web/dist/assets/
/web/dist/vite.svg
/web/.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local env / secrets
.env
.env.*
!.env.example
!.env.*.example

# Editor / OS
.DS_Store
*.swp
.idea/
.vscode/

# Local runtime data (should live under ~/.podium, never in-repo)
/.podium/
/.claude/settings.local.json

# Scratch / coverage output
/tmp/
/coverage/
/coverage.html

# Design source export (large binary; kept local, not in git history)
/Podium frontend design.zip
